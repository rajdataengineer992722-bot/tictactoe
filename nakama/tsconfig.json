{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "build",
    "rootDir": "src",
    "typeRoots": ["./types"]
  },
  "include": ["src/**/*.ts", "types/**/*.d.ts"]
}
